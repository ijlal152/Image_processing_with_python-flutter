# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1

# Server Configuration
HOST=0.0.0.0
PORT=5000

# Upload Configuration
MAX_CONTENT_LENGTH=16777216  # 16MB in bytes
UPLOAD_FOLDER=uploads
ENHANCED_FOLDER=enhanced

# Security
SECRET_KEY=your-secret-key-change-in-production

# Image Processing
DEFAULT_METHOD=auto
MAX_IMAGE_SIZE=4096
